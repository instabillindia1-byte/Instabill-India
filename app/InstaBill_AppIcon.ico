<svg width="512" height="512" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
  <!-- App icon - 512x512 for app stores -->
  <rect width="512" height="512" rx="112" fill="#3C3489"/>
  <rect width="512" height="40" rx="20" fill="#26215C" opacity="0.5"/>

  <!-- Invoice paper -->
  <rect x="136" y="96" width="240" height="300" rx="24" fill="none" stroke="#FFFFFF" stroke-width="10"/>
  <!-- Fold corner -->
  <polyline points="316,96 316,156 376,156" fill="none" stroke="#FFFFFF" stroke-width="9" stroke-linejoin="round"/>
  <polygon points="316,96 376,156 316,156" fill="#7F77DD" opacity="0.4"/>

  <!-- Document lines -->
  <line x1="168" y1="196" x2="300" y2="196" stroke="#FFFFFF" stroke-width="10" stroke-linecap="round"/>
  <line x1="168" y1="236" x2="300" y2="236" stroke="#FFFFFF" stroke-width="10" stroke-linecap="round"/>
  <line x1="168" y1="276" x2="260" y2="276" stroke="#FFFFFF" stroke-width="10" stroke-linecap="round" opacity="0.6"/>

  <!-- Lightning bolt centered -->
  <polygon points="256,306 224,364 248,364 212,430 288,358 260,358 292,306" fill="#EF9F27"/>
  <polygon points="256,306 240,330 254,330 232,364 258,306" fill="#FAC775" opacity="0.7"/>
</svg>
